{
  "$id": "presentation_plan.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Presentation Plan Schema",
  "type": "object",
  "required": [
    "presentation_title",
    "slides"
  ],
  "properties": {
    "presentation_title": {
      "type": "string"
    },
    "slides": {
      "type": "array",
      "items": {
        "$ref": "slide.schema.json"
      }
    }
  },
  "additionalProperties": false
}