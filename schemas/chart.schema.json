{
  "$id": "chart.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Chart Schema",
  "type": "object",
  "required": [
    "type",
    "data"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "bar",
        "line",
        "pie"
      ]
    },
    "data": {
      "type": "object",
      "required": [
        "labels",
        "values"
      ],
      "properties": {
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "values": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    },
    "title": {
      "type": "string"
    }
  },
  "additionalProperties": false
}